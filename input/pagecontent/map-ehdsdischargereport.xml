    <h3>EHDSDischargeReport -> Composition (HDR)</h3>
    <a> </a>
    <p></p>
    <p>
      This page explains how conceptual elements from the EHDSDischargeReport logical model are expressed
      in the corresponding FHIR CompositionEuHdr profile used by this Implementation Guide.
    </p>
    <p></p>
    <div class="table-wrap">
      <strong>Mapping Context</strong>
      <ul>
        <li>
          <strong>Source logical model:</strong>
          <a href="https://www.xt-ehr.eu/fhir/models/1.0.0/StructureDefinition-EHDSDischargeReport.html" target="_blank">
            EHDSDischargeReport
          </a>
        </li>
        <li>
          <strong>Target FHIR profile:</strong>
          <a href="StructureDefinition-composition-eu-hdr.html">
            CompositionEuHdr
          </a>
        </li>
      </ul>
    </div>
    <p></p>
    <div class="table-wrap">
      <table summary="EHDSDischargeReport -> Composition (HDR)">
        <caption>EHDSDischargeReport -> Composition (HDR)</caption>
        <thead>
          <tr>
            <th colspan="1" class="src-head">EHDSDischargeReport (Logical Model)</th>
            <th class="relhead">Relationship</th>
            <th colspan="3" class="tgt-head">Composition (HDR)</th>
          </tr>
          <tr>
            <th class="src-sub">Element</th>
            <th class="relsub">Relation</th>
            <th class="tgt-sub">Resource</th>
            <th class="tgt-sub">Element</th>
            <th class="tgt-sub">Notes</th>
          </tr>
        </thead>
        <tbody>
          <!-- HEADER BLOCK -->
          <tr>
            <td>header</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>.</td>
            <td>CompositionEuHdr constrains header elements for HDR.</td>
          </tr>
          <tr>
            <td>header.author[x]</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>author</td>
            <td>Reference to Practitioner/PractitionerRole/Organization/Device per profile.</td>
          </tr>
          <tr>
            <td>header.status</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>status</td>
            <td></td>
          </tr>
          <tr>
            <td>header.documentType</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>type</td>
            <td>Fixed to LOINC 34105-7 in CompositionEuHdr.</td>
          </tr>
          <tr>
            <td>header.documentTitle</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>title</td>
            <td></td>
          </tr>
          <tr>
            <td>header.period</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>event.period</td>
            <td>Map to the primary Composition.event entry.</td>
          </tr>
          <tr>
            <td>header.intendedRecipient[x]</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>extension:information-recipient</td>
            <td>Uses the information-recipient extension in CompositionEuHdr.</td>
          </tr>
          <tr>
            <td>body</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section</td>
            <td>CompositionEuHdr represents body content as sliced Composition sections plus the Composition.encounter reference.</td>
          </tr>

          <!-- ALERTS -->
          <tr>
            <td>body.alerts</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionAlert</td>
            <td>Use LOINC 104605-1.</td>
          </tr>
          <tr>
            <td>body.alerts.generatedNarrative</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionAlert.text</td>
            <td></td>
          </tr>
          <tr>
            <td>body.alerts.medicalAlert</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionAlert.entry</td>
            <td>Reference to Flag (EHDSAlert).</td>
          </tr>

          <!-- ENCOUNTER INFORMATION -->
          <tr>
            <td>body.encounterInformation</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>encounter</td>
            <td>Use EncounterEuHdr.</td>
          </tr>
          <tr>
            <td>body.encounterInformation.generatedNarrative</td>
            <td>related-to</td>
            <td>Encounter</td>
            <td>text</td>
            <td></td>
          </tr>
          <tr>
            <td>body.encounterInformation.encounter</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>encounter</td>
            <td></td>
          </tr>
          <tr>
            <td>body.encounterInformation.note</td>
            <td>related-to</td>
            <td>Encounter</td>
            <td>text</td>
            <td>No dedicated encounter-information section is active in CompositionEuHdr.</td>
          </tr>

          <!-- ADMISSION EVALUATION -->
          <tr>
            <td>body.admissionEvaluation</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionAdmissionEvaluation</td>
            <td>Reported only if relevant.</td>
          </tr>
          <tr>
            <td>body.admissionEvaluation.generatedNarrative</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionAdmissionEvaluation.text</td>
            <td></td>
          </tr>
          <tr class="highlight-yellow">
            <td>body.admissionEvaluation.objectiveFindings</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionVitalSigns</td>
            <td>Use Observation where appropriate; anthropometric measurements may be represented here when treated as vital-sign observations.</td>
          </tr>
          <tr class="highlight-yellow">
            <td>body.admissionEvaluation.objectiveFindings</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionPhysicalFindings</td>
            <td>Use Observation where appropriate.</td>
          </tr>
          <tr>
            <td>body.admissionEvaluation.functionalStatus[x]</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionFunctionalStatus.entry</td>
            <td>Source allows EHDSCondition or EHDSObservation; the FHIR profile also permits ClinicalImpression, DocumentReference, and QuestionnaireResponse entries.</td>
          </tr>
          <tr>
            <td>body.admissionEvaluation.note</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionAdmissionEvaluation.text</td>
            <td></td>
          </tr>

          <!-- Hx general Reported -->
          <tr>
            <td>body.patientHistory</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionPatientHx</td>
            <td></td>
          </tr>
          <tr>
            <td>body.patientHistory.generatedNarrative</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionPatientHx.text</td>
            <td></td>
          </tr>
          <tr>
            <td>body.patientHistory.pastProblems</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionPatientHx.text / section:sectionProblems.entry</td>
            <td>Use sectionPatientHx for anamnesis context; use sectionProblems when represented as problem entries.</td>
          </tr>
          <tr>
            <td>body.patientHistory.devicesAndImplants</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionPatientHx.text / section:sectionMedicalDevices.entry</td>
            <td>Use sectionMedicalDevices for patient history of medical device use.</td>
          </tr>
          <tr>
            <td>body.patientHistory.procedures</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionPatientHx.text / section:sectionProceduresHx.entry</td>
            <td>Use sectionProceduresHx for past procedures relevant to the document scope.</td>
          </tr>
          <tr>
            <td>body.patientHistory.note</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionPatientHx.extension:section-note</td>
            <td></td>
          </tr>

          <!-- COURSE OF ENCOUNTER -->
          <tr>
            <td>body.courseOfEncounter</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionHospitalCourse</td>
            <td></td>
          </tr>
          <tr>
            <td>body.courseOfEncounter.generatedNarrative</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionHospitalCourse.text</td>
            <td></td>
          </tr>
          <tr>
            <td>body.courseOfEncounter.diagnosticSummary</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionDiagnosticSummary.entry</td>
            <td>Reference to ConditionEuCore.</td>
          </tr>
          <tr>
            <td>body.courseOfEncounter.procedures</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionSignificantProcedures.entry</td>
            <td>Reference to ProcedureEuCore.</td>
          </tr>
          <tr>
            <td>body.courseOfEncounter.medicalDevicesAndImplants</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionImplantedDevices.entry</td>
            <td>Reference to DeviceUseStatementEuHdr.</td>
          </tr>
          <tr>
            <td>body.courseOfEncounter.pharmacotherapy</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionPharmacotherapy.entry</td>
            <td>MedicationStatement/Request/Dispense/Administration.</td>
          </tr>
          <tr>
            <td>body.courseOfEncounter.testResults[x]</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionSignificantResults.entry</td>
            <td>EHDSObservation and EHDSLaboratoryObservation map to Observation-oriented entries; DiagnosticReport/DocumentReference are also allowed by CompositionEuHdr.</td>
          </tr>
          <tr>
            <td>body.courseOfEncounter.note</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionHospitalCourse.text</td>
            <td></td>
          </tr>

          <!-- DISCHARGE DETAILS -->
          <tr>
            <td>body.dischargeDetails</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionDischargeDetails</td>
            <td></td>
          </tr>
          <tr>
            <td>body.dischargeDetails.generatedNarrative</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionDischargeDetails.text</td>
            <td></td>
          </tr>
          <tr class="highlight-yellow">
            <td>body.dischargeDetails.objectiveFindings</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionPhysicalFindings / section:sectionVitalSigns / section:sectionSignificantResults</td>
            <td>No discharge-specific objective-findings section is defined in CompositionEuHdr.</td>
          </tr>
          <tr>
            <td>body.dischargeDetails.functionalStatus[x]</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionFunctionalStatus.entry</td>
            <td></td>
          </tr>
          <tr>
            <td>body.dischargeDetails.note</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionDischargeDetails.text</td>
            <td></td>
          </tr>

          <!-- MEDICATION SUMMARY -->
          <tr>
            <td>body.medicationSummary</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionDischargeMedications</td>
            <td>Post-discharge medications summary.</td>
          </tr>
          <tr>
            <td>body.medicationSummary.generatedNarrative</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionDischargeMedications.text</td>
            <td></td>
          </tr>
          <tr>
            <td>body.medicationSummary.medicationUse</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionDischargeMedications.entry</td>
            <td>MedicationRequest/MedicationDispense/MedicationStatement.</td>
          </tr>
          <tr>
            <td>body.medicationSummary.note</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionDischargeMedications.text</td>
            <td></td>
          </tr>

          <!-- CARE PLAN -->
          <tr>
            <td>body.carePlan</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionPlanOfCare</td>
            <td></td>
          </tr>
          <tr>
            <td>body.carePlan.generatedNarrative</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionPlanOfCare.text</td>
            <td></td>
          </tr>
          <tr>
            <td>body.carePlan.carePlan</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionPlanOfCare.entry</td>
            <td>Reference to CarePlanEuHdr.</td>
          </tr>
          <tr>
            <td>body.carePlan.otherRecommendations</td>
            <td>related-to</td>
            <td>Composition</td>
            <td>section:sectionPlanOfCare.text</td>
            <td>sectionDischargeInstructions is no longer active in CompositionEuHdr.</td>
          </tr>

          <!-- SYNTHESIS -->
          <tr>
            <td>body.synthesis</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionSynthesis.text</td>
            <td></td>
          </tr>

          <!-- ATTACHMENTS -->
          <tr>
            <td>attachments</td>
            <td>equivalent</td>
            <td>Composition</td>
            <td>section:sectionAttachments.entry</td>
            <td>DocumentReference/Binary in CompositionEuHdr.</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p style="margin-top:2rem;color:#555;">
      Return to overview: <a href="modelmap.html">EHDS Logical Models -> FHIR Profiles</a>
    </p>
  </body>
